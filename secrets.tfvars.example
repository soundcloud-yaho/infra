# secrets.tfvars.example
# 사용법:
#   cp secrets.tfvars.example secrets.tfvars
#   secrets.tfvars에 실제 값 입력 후 create_secrets.sh 실행
#
# ⚠️  secrets.tfvars는 .gitignore 처리됨 — Git에 절대 올리지 말 것
#     이 파일(example)만 Git에 올림

# Tailscale 인증키
# 발급: https://login.tailscale.com/admin/settings/keys
tailscale_auth_key = "tskey-auth-xxxx"

# Slack Webhook URL
# 발급: https://api.slack.com/apps → Incoming Webhooks
slack_webhook_url = "https://hooks.slack.com/services/xxxx/xxxx/xxxx"

# Grafana 관리자 비밀번호
grafana_admin_password = "your-secure-password"
